<script>
// ===== PAGE LOAD =====
window.addEventListener('load', () => setTimeout(() => document.body.classList.add('loaded'), 80));

// ===== HERO VIDEO LAZY LOADING =====
(function() {
  const video = document.getElementById('hero-video');
  const frame = document.getElementById('hero-frame');
  if (!video || !frame) return;

  if (video.readyState >= 3) {
    frame.classList.add('video-loaded');
    return;
  }

  video.addEventListener('canplay', function() {
    frame.classList.add('video-loaded');
  }, { once: true });

  setTimeout(function() {
    frame.classList.add('video-loaded');
  }, 8000);
})();

// ===== SCROLL REVEAL =====
const io = new IntersectionObserver(e => e.forEach(x => {
  if(x.isIntersecting) x.target.classList.add('visible');
}), {threshold:.1, rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

// ===== STATS BOX REVEAL =====
const heroStatBoxes = document.querySelectorAll('.hero-stat-box');
const hsbio = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if(entry.isIntersecting) {
      heroStatBoxes.forEach((box, i) => setTimeout(() => box.classList.add('visible'), i * 130));
      hsbio.disconnect();
    }
  });
}, {threshold: .1});
if(heroStatBoxes[0]) hsbio.observe(heroStatBoxes[0].closest('.hero-stats') || heroStatBoxes[0]);

// ===== COUNTER ANIMATION =====
const cio = new IntersectionObserver(entries => {
  if(entries[0].isIntersecting) {
    document.querySelectorAll('.hero-stat-number').forEach(el => {
      const target = parseInt(el.dataset.target);
      const prefix = el.dataset.prefix || '';
      let c = 0;
      const step = Math.ceil(target / 60);
      const t = setInterval(() => {
        c = Math.min(c + step, target);
        el.textContent = prefix + c.toLocaleString('fr-FR');
        if(c >= target) clearInterval(t);
      }, 20);
    });
    cio.disconnect();
  }
}, {threshold: .1});
const heroStatsSection = document.querySelector('.hero-stats');
if(heroStatsSection) cio.observe(heroStatsSection);

// ===== HAMBURGER MENU =====
const hb = document.querySelector('.hamburger');
const nl = document.querySelector('.nav-links');

function closeMenu() {
  nl.removeAttribute('style');
  nl.classList.remove('mobile-open');
  hb.setAttribute('aria-expanded', 'false');
}

hb.addEventListener('click', () => {
  const isOpen = nl.classList.contains('mobile-open');
  if(isOpen) {
    closeMenu();
  } else {
    nl.classList.add('mobile-open');
    Object.assign(nl.style, {
      display: 'flex', position: 'fixed',
      top: '68px', left: '0', right: '0',
      flexDirection: 'column', background: 'var(--papier)',
      padding: '1.5rem 2rem', borderBottom: '2px solid var(--rouge)',
      zIndex: '400', gap: '1.2rem'
    });
    hb.setAttribute('aria-expanded', 'true');
  }
});

nl.querySelectorAll('a').forEach(a => {
  a.addEventListener('click', () => { if(window.innerWidth < 768) closeMenu(); });
});

window.addEventListener('resize', () => {
  if(window.innerWidth >= 768) { nl.removeAttribute('style'); nl.classList.remove('mobile-open'); }
});

// ===== NAV SHADOW =====
window.addEventListener('scroll', () => {
  document.querySelector('nav').style.boxShadow = window.scrollY > 40 ? '0 4px 30px rgba(0,0,0,.07)' : 'none';
});

// ===== SMOOTH SCROLL =====
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const href = a.getAttribute('href');
    if(href === '#') return;
    e.preventDefault();
    const t = document.querySelector(href);
    if(t) { t.scrollIntoView({behavior: 'smooth'}); if(window.innerWidth < 768) closeMenu(); }
  });
});

// ===== AMBIENT MUSIC =====
(function() {
  const audio = document.getElementById('ambient-audio');
  const btn   = document.getElementById('music-toggle');
  if (!audio || !btn) return;

  audio.volume = 0.35;

  function setPlaying() {
    btn.classList.add('playing');
    btn.setAttribute('aria-label', "Désactiver la musique d'ambiance");
  }

  function setPaused() {
    btn.classList.remove('playing');
    btn.setAttribute('aria-label', "Activer la musique d'ambiance");
  }

  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    if (audio.paused) {
      audio.play().then(setPlaying).catch(() => {});
    } else {
      audio.pause();
      setPaused();
    }
  });
})();

// ===== NEWSLETTER SUBMISSION =====
const NEWSLETTER_APP_URL = 'https://script.google.com/macros/s/VOTRE_URL_ICI/exec';

const nlForm = document.getElementById('nl-form');
const nlEmail = document.getElementById('nl-email');
const nlSubmit = document.getElementById('nl-submit');
const nlMsg = document.getElementById('nl-msg');

if(nlForm) {
  nlForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = nlEmail.value.trim();
    if(!email) return;

    nlSubmit.disabled = true;
    nlSubmit.textContent = 'Envoi...';
    nlMsg.className = 'nl-msg';
    nlMsg.textContent = '';

    try {
      const res = await fetch(NEWSLETTER_APP_URL, {
        method: 'POST',
        body: JSON.stringify({ email: email })
      });
      const data = await res.json();

      if(data.status === 'ok') {
        nlMsg.textContent = "Merci ! Votre inscription a bien été prise en compte.";
        nlMsg.classList.add('success');
        nlForm.reset();
      } else {
        throw new Error(data.message || 'Erreur serveur');
      }
    } catch(err) {
      console.error(err);
      nlMsg.textContent = "Une erreur est survenue. Veuillez réessayer ultérieurement.";
      nlMsg.classList.add('error');
    } finally {
      nlSubmit.disabled = false;
      nlSubmit.textContent = "S'inscrire";
    }
  });
}
</script>
</body>
</html>
