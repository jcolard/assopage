/* ===== MUSIC PLAYER ===== */
.music-btn {
  position: fixed;
  bottom: 2rem;
  left: 2rem;
  z-index: 9100;
  width: 52px;
  height: 52px;
  background: var(--noir);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  clip-path: polygon(0 0,100% 0,94% 100%,6% 100%);
  box-shadow: 0 6px 24px rgba(0,0,0,.4);
  transition: background .25s, transform .22s, box-shadow .22s;
  outline: none;
  padding: 0;
}
.music-btn:hover {
  background: var(--rouge);
  transform: translateY(-3px);
  box-shadow: 0 12px 32px rgba(216,0,0,.4);
}
.music-btn svg { width: 20px; height: 20px; flex-shrink: 0; }
.music-btn .icon-play  { display: block; }
.music-btn .icon-pause { display: none; }
.music-btn.playing .icon-play  { display: none; }
.music-btn.playing .icon-pause { display: block; }

.music-btn::after {
  content: 'Musique';
  position: absolute;
  left: calc(100% + 12px);
  top: 50%;
  transform: translateY(-50%);
  background: var(--noir);
  color: white;
  font-family: 'Manrope', sans-serif;
  font-size: .68rem;
  font-weight: 800;
  letter-spacing: .12em;
  text-transform: uppercase;
  padding: .45rem .9rem;
  white-space: nowrap;
  clip-path: polygon(0 0,100% 0,96% 100%,4% 100%);
  opacity: 0;
  pointer-events: none;
  transition: opacity .2s;
}
.music-btn:hover::after { opacity: 1; }

.music-waves {
  position: absolute;
  inset: 0;
  pointer-events: none;
  display: none;
}
.music-btn.playing .music-waves { display: block; }
.music-waves span {
  position: absolute;
  inset: 0;
  border: 2px solid var(--rouge);
  clip-path: polygon(0 0,100% 0,94% 100%,6% 100%);
  animation: musicPulse 2s ease-out infinite;
  opacity: 0;
}
.music-waves span:nth-child(2) { animation-delay: .65s; }
.music-waves span:nth-child(3) { animation-delay: 1.3s; }
@keyframes musicPulse {
  0%   { transform: scale(1);   opacity: .75; }
  100% { transform: scale(1.85); opacity: 0; }
}

